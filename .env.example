# ---------------------------------------------------------------------------
# Morpheus — variáveis de ambiente
# Copie este arquivo para ".env" na raiz do projeto e ajuste os valores.
# ---------------------------------------------------------------------------

# Ambiente
NODE_ENV=development

# Portas
API_PORT=3001
WEB_PORT=3000

# CORS (origem permitida para a Web consumir a API)
CORS_ORIGIN=http://localhost:3000

# Banco de dados (Postgres)
POSTGRES_USER=morpheus
POSTGRES_PASSWORD=morpheus
POSTGRES_DB=morpheus
POSTGRES_PORT=5432
DATABASE_URL=postgresql://morpheus:morpheus@localhost:5432/morpheus?schema=public

# JWT (Etapa 3 — Autenticação e RBAC)
JWT_ACCESS_SECRET=change-me-access-secret-please-rotate
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-please-rotate
JWT_REFRESH_EXPIRES_IN=7d

# SSO via SAML genérico (desabilitado por padrão em dev — login local com
# email/senha funciona sem nenhuma destas variáveis)
SAML_ENABLED=false
SAML_ENTRY_POINT=
SAML_ISSUER=morpheus
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:3001/auth/saml/callback
SAML_TENANT_SLUG=demo

# Pareceres técnicos em PDF (Etapa 7)
# PUBLIC_API_URL: base usada para montar o link de verificação codificado no
# QR Code do parecer — precisa ser alcançável por quem escaneia o QR, não só
# pela rede interna (em produção, o domínio público da API).
PUBLIC_API_URL=http://localhost:3001
# STORAGE_DIR: onde os PDFs gerados ficam salvos (adapter de disco local —
# ver módulo storage). Trocar por um adapter S3 no futuro (Etapa 16) não
# muda esta variável, só a implementação do adapter.
STORAGE_DIR=./storage

# Notificações por e-mail (Etapa 10) — sem SMTP_HOST, o NotificationsService
# ainda grava a notificação normalmente, só não tenta enviar e-mail (log
# avisando em vez de derrubar a ação que disparou a notificação).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Morpheus <no-reply@morpheus.local>
# Dias de antecedência para marcar um item do inventário como PENDING_REVIEW
# e notificar o responsável (job diário).
INVENTORY_REVIEW_WARNING_DAYS=30

# Observabilidade e hardening (Etapa 14)
# OTEL_EXPORTER_OTLP_ENDPOINT vazio = spans vão para o console (não precisa
# de um collector rodando em dev/CI). THROTTLE_* controlam o rate limit
# global (por IP); endpoints sensíveis têm limites mais estritos no código.
OTEL_SERVICE_NAME=morpheus-api
OTEL_EXPORTER_OTLP_ENDPOINT=
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
# Chave AES-256 em base64 (32 bytes) para o CryptoService — gere a sua com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Frontend
# API_URL: usado pela Web server-side (rota de proxy) para chamar a API — em
# dev local os dois rodam na mesma máquina, então "localhost" está correto;
# dentro do Docker Compose isso é sobrescrito para "http://api:3001" (ver
# docker-compose.yml), nunca lido daqui.
API_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL: reservado para o dia em que um componente cliente
# (browser) precisar chamar a API diretamente. Ainda não é usado por nada.
NEXT_PUBLIC_API_URL=http://localhost:3001
